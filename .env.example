# =========================
# SmartCV Environment Setup
# =========================
#
# Notes:
# - Variables prefixed with VITE_ are exposed to the browser.
# - Server-only secrets (like Gemini API keys) must NOT use the VITE_ prefix.
#
# For Vercel:
# - Add these under Project → Settings → Environment Variables.

# ---------------------------------
# Gemini (server-side, REQUIRED*)
# ---------------------------------
# Used by:
# - Interview Question Generator (`/api/generate-questions`)
# - Cover Letter Generator (`/api/generate-cover-letter`)
#
# Get a key from Google AI Studio:
# - https://aistudio.google.com/app/apikey
#
# REQUIRED if you want Interview/Cover Letter features to work.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional alias (some setups use GOOGLE_API_KEY instead of GEMINI_API_KEY).
# If both are provided, GEMINI_API_KEY is used first.
GOOGLE_API_KEY=

# ---------------------------------
# Gemini model override (client, OPTIONAL)
# ---------------------------------
# If set, this becomes the PRIMARY model used by the server fallback chain,
# ahead of the default chain. Useful if a specific model is consistently down.
#
# Default value:
VITE_GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------
# JSearch (client-side, REQUIRED*)
# ---------------------------------
# Used by:
# - Job Search page (`/jobs`) to call RapidAPI JSearch from the browser
#
# Get your key from RapidAPI:
# - https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Steps:
# 1) Sign up for RapidAPI
# 2) Subscribe to JSearch API (free tier available)
# 3) Copy your API key from the dashboard
#
# REQUIRED if you want Job Search to work.
VITE_JSEARCH_API_KEY=your_jsearch_api_key_here
